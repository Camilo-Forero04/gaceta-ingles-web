# Base de datos (Supabase/PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/db"

# Wompi
WOMPI_PUB_KEY="pub_prod_xxxx"
WOMPI_INTEGRITY_SECRET="prod_integrity_xxxx"
# Secreto de EVENTOS (distinto al de integridad). Se obtiene en el panel de Wompi > Desarrolladores.
WOMPI_EVENTS_SECRET="prod_events_xxxx"

# Resend (correos transaccionales)
RESEND_API_KEY="re_xxxx"

# Facebook Conversions API
FACEBOOK_ACCESS_TOKEN=""
FACEBOOK_PIXEL_ID=""

# Enlace del grupo VIP de WhatsApp (va en el correo de bienvenida)
WHATSAPP_GROUP_URL="https://chat.whatsapp.com/xxxx"

# Entorno
NODE_ENV="production"
PORT=4000
